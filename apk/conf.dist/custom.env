# This custom.env file is concatenated with 'version' file, and
# stored as the default ".env" file.
#
TZ=Etc/GMT

WEB_HTTP=0.0.0.0:5010
WEB_HTTPS=0.0.0.0:5011

FTLCONF_webserver_api_password=admin

# If using Docker's default `bridge` network setting the dns listening mode should be set to 'ALL'
FTLCONF_dns_listeningMode: 'ALL'

# Disable regenerating the self-signed certificate, since
# we'll use the current active certificate
FTLCONF_webserver_tls_validity: 0

FTLCONF_ntp_ipv4_active: false
FTLCONF_ntp_ipv6_active: false

# Toggled by the Settings tab. When 'true', the Settings save step rewrites
# compose.yml to expose 67/udp and grant NET_ADMIN so Pi-hole can act as a
# DHCP server.
DHCP_PASSTHROUGH=false

# Use 'admin' account
PIHOLE_UID=999
PIHOLE_GID=999
